# Date        Version  Author   Description
# 2026-01-24  0.0.1    mrosiere Created
#-----------------------------------------------------------------------------

name        : asylum:processor:WardRV:0.0.1
description : WardRV


#=========================================
filesets:
#=========================================
  #---------------------------------------
  files_hdl:
  #---------------------------------------
    files        :
      - hdl/RV_pkg.vhd
      - hdl/WardRV_pkg.vhd
      - hdl/iss/WardRV_iss_pkg.vhd
      - hdl/debug/WardRV_debug_pkg.vhd
      - hdl/debug/WardRV_debug.vhd
      - hdl/fsm/WardRV_fsm.vhd
      - hdl/tiny/WardRV_tiny_decode.vhd
      - hdl/tiny/WardRV_tiny_execute.vhd
      - hdl/tiny/WardRV_tiny_lsu_8b.vhd
      - hdl/tiny/WardRV_tiny_lsu.vhd
      - hdl/tiny/WardRV_tiny_pc.vhd
      - hdl/tiny/WardRV_tiny_pkg.vhd
      - hdl/tiny/WardRV_tiny.vhd

    file_type    : vhdlSource-2008
    logical_name : asylum
    depend       :
      - ">=asylum:utils:pkg:1.0.0"
      - ">=asylum:component:ram:1.0.0"

  #---------------------------------------
  files_sim:
  #---------------------------------------
    files        :
      - sim/WardRV_vips.vhd                                          
      - sim/tb_WardRV_pkg.vhd                                        
      - sim/tb_WardRV.vhd                                            
      - sim/tb_WardRV_iss.vhd                                        
      - esw/testcase/build/firmware.hex                              : {file_type : user, copyto : firmware.hex}
      - esw/compliance/benchs                                        : {file_type : user, copyto : benchs}

    file_type    : vhdlSource-2008
    depend :
      - bitvis:verification:uvvm
      
#=========================================
targets:
#=========================================

  #---------------------------------------
  # Default Target
  #---------------------------------------
  default: &default
    description     : Default Target
    filesets        :
      - files_hdl
    toplevel        : WardRV
    default_tool    : ghdl

  #---------------------------------------
  sim: &sim
  #---------------------------------------
    << : *default
    description     : default rule to sim (DON'T RUN)
    default_tool    : ghdl
    toplevel        : tb_WardRV_iss
    filesets_append :
      - files_sim
    tools :
      ghdl :
        analyze_options : ["-Wall","-fsynopsys","-frelaxed","--no-vital-checks"]
        run_options     : ["--fst=dut.fst","--ieee-asserts=disable"]

  ##---------------------------------------
  #sim_basic:
  ##---------------------------------------
  #  << : *sim
  #  description     : Basic testcase
  #  parameters      :
  #    - FIRMWARE_FILE=firmware.hex
  #    - VERBOSE=false
  #  tools :
  #    ghdl :
  #      analyze_options : ["-Wall","-fsynopsys","-frelaxed","--no-vital-checks"]
  #      run_options     : ["--fst=dut.fst","--ieee-asserts=disable"]

  #---------------------------------------
  # Compliance Testcases
  #---------------------------------------
  sim_compliance_add_01:
    << : *sim
    description: Add-01 testcase
    parameters: [FIRMWARE_FILE=benchs/add-01.hex, GOLDEN_FILE=benchs/add-01.signature, VERBOSE=false]

  sim_compliance_addi_01:
    << : *sim
    description: Addi-01 testcase
    parameters: [FIRMWARE_FILE=benchs/addi-01.hex, GOLDEN_FILE=benchs/addi-01.signature, VERBOSE=false]

  sim_compliance_and_01:
    << : *sim
    description: And-01 testcase
    parameters: [FIRMWARE_FILE=benchs/and-01.hex, GOLDEN_FILE=benchs/and-01.signature, VERBOSE=false]

  sim_compliance_andi_01:
    << : *sim
    description: Andi-01 testcase
    parameters: [FIRMWARE_FILE=benchs/andi-01.hex, GOLDEN_FILE=benchs/andi-01.signature, VERBOSE=false]

  sim_compliance_auipc_01:
    << : *sim
    description: Auipc-01 testcase
    parameters: [FIRMWARE_FILE=benchs/auipc-01.hex, GOLDEN_FILE=benchs/auipc-01.signature, VERBOSE=false]

