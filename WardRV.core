#=========================================
parameters :
#=========================================

  FIRMWARE_FILE :
    description : Firmware
    datatype    : str
    default     : firmware.hex
    paramtype   : generic

  GOLDEN_FILE :
    description : Golden signature file
    datatype    : str
    default     : golden.hex
    paramtype   : generic

  VERBOSE :
    description : Verbose mode
    datatype    : bool
    default     : true
    paramtype   : generic
