CAPI=2:

#-----------------------------------------------------------------------------
# Title      : WardRV Core file
# Project    : Asylum
#-----------------------------------------------------------------------------
# File       : WardRV.core
# Author     : mrosiere
#-----------------------------------------------------------------------------
# Description: 
